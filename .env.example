# .env.example
# Copia este archivo como .env.local y completa los valores

# ─── PostgreSQL (Supabase) ───────────────────────────────────────────────────
# Obtén estas URLs en: supabase.com → tu proyecto → Settings → Database
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Obtén estas claves en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # ⚠️ Nunca exponer en el cliente

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Obtén tu clave en: platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"
